{
  "info": {
    "name": "FitLife Classes",
    "description": "Postman collection for the FitLife Classes microservice. Use the jwtToken variable with a Bearer token from Identity.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5245" },
    { "key": "identityBaseUrl", "value": "http://localhost:5244" },
    { "key": "jwtToken", "value": "" },
    { "key": "classId", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "memberId", "value": "22222222-2222-2222-2222-222222222222" },
    { "key": "trainerId", "value": "11111111-1111-1111-1111-111111111111" }
  ],
  "item": [
    {
      "name": "Public - Health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/healthz"
      }
    },
    {
      "name": "Public - Swagger",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/swagger"
      }
    },
    {
      "name": "Identity - Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"member@example.com\",\n  \"password\": \"Password123!\"\n}"
        },
        "url": "{{identityBaseUrl}}/auth/login"
      }
    },
    {
      "name": "Classes - Get all without JWT should return 401",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/classes"
      }
    },
    {
      "name": "Classes - Get all",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{jwtToken}}", "type": "string" }
          ]
        },
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/classes"
      }
    },
    {
      "name": "Classes - Create",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{jwtToken}}", "type": "string" }
          ]
        },
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Morning HIIT\",\n  \"description\": \"High intensity interval training for all levels.\",\n  \"category\": \"HIIT\",\n  \"difficultyLevel\": \"Beginner\",\n  \"startTime\": \"2026-05-06T08:00:00Z\",\n  \"endTime\": \"2026-05-06T08:45:00Z\",\n  \"location\": \"Vesterbro\",\n  \"capacity\": 20,\n  \"availableSpots\": 20,\n  \"trainerId\": \"{{trainerId}}\"\n}"
        },
        "url": "{{baseUrl}}/api/classes"
      }
    },
    {
      "name": "Classes - Get by id",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{jwtToken}}", "type": "string" }
          ]
        },
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/classes/{{classId}}"
      }
    },
    {
      "name": "Classes - Update",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{jwtToken}}", "type": "string" }
          ]
        },
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Morning HIIT Updated\",\n  \"description\": \"Updated class description.\",\n  \"category\": \"HIIT\",\n  \"difficultyLevel\": \"Intermediate\",\n  \"startTime\": \"2026-05-06T08:00:00Z\",\n  \"endTime\": \"2026-05-06T08:45:00Z\",\n  \"location\": \"Vesterbro\",\n  \"capacity\": 20,\n  \"availableSpots\": 18,\n  \"trainerId\": \"{{trainerId}}\"\n}"
        },
        "url": "{{baseUrl}}/api/classes/{{classId}}"
      }
    },
    {
      "name": "Classes - Book",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{jwtToken}}", "type": "string" }
          ]
        },
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"memberId\": \"{{memberId}}\"\n}"
        },
        "url": "{{baseUrl}}/api/classes/{{classId}}/bookings"
      }
    },
    {
      "name": "Classes - Cancel booking",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{jwtToken}}", "type": "string" }
          ]
        },
        "method": "PUT",
        "header": [],
        "url": "{{baseUrl}}/api/classes/{{classId}}/bookings/{{bookingId}}/cancel"
      }
    },
    {
      "name": "Classes - Amend booking",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{jwtToken}}", "type": "string" }
          ]
        },
        "method": "PUT",
        "header": [],
        "url": "{{baseUrl}}/api/classes/{{classId}}/bookings/{{bookingId}}/amend"
      }
    },
    {
      "name": "Classes - Delete",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            { "key": "token", "value": "{{jwtToken}}", "type": "string" }
          ]
        },
        "method": "DELETE",
        "header": [],
        "url": "{{baseUrl}}/api/classes/{{classId}}"
      }
    }
  ]
}
